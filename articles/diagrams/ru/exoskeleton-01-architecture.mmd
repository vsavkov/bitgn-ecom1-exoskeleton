flowchart TB
    IN(["Задача trial:<br/>текст + изолированный слепок ECOM OS"])

    subgraph S0["(1) Старт"]
        WARM("Карта среды → контекст<br/>/AGENTS.MD · дерево · /docs · /bin · date · id<br/>(синтетическими парами «вызов → результат»)")
        CLS("Классификатор намерения<br/>gpt-5.4-nano · high")
    end

    subgraph S1["(2) Предварительные проверки · детерминированный код"]
        NORM("Нормализация флагов · код:<br/>усилить/снять подозрение на подмену<br/>по «радиусу поражения» задачи")
        SEC("Безопасность + /bin/id")
        OTHER("Прочие предварительные проверки:<br/>дата · возврат · /tmp · подсчёт ·<br/>город · fraud-история · выбор корзины")
    end

    subgraph S2["(3) Основной цикл"]
        DISP("Диспетчер · gpt-5.4-mini · high<br/>Responses API · tool_choice=required<br/>несколько вызовов за шаг")
        TOOLS("Инструменты среды<br/>tree · find · read · exec · …")
        HELP("Доменные помощники:<br/>каталог и наличие · сверка чека ·<br/>план отправки · фрод-анализ ·<br/>восстановление 3DS · проверка менеджера ·<br/>подсчёт сотрудников")
    end

    subgraph S3["(4) Сборка ответа · детерминированный код"]
        LED("Журнал доказательств:<br/>копит ссылки от помощников<br/>и доливает их в финал")
        REF("Нормализация ссылок")
        FMT("Форматтер · gpt-5.4-nano · high")
    end

    OUT(["answer( исход · сообщение · ссылки-доказательства )"])
    OBS("Наблюдаемость:<br/>артефакты → тепловая карта · трейсы")

    IN --> WARM --> CLS --> NORM --> SEC --> OTHER
    OTHER -->|сработала предварительная проверка| LED
    OTHER -->|чисто| DISP
    DISP <--> TOOLS
    DISP <--> HELP
    DISP -->|report_completion| LED
    LED --> REF --> FMT --> OUT
    OUT -.->|после прогона| OBS

classDef io fill:#334155,stroke:#94a3b8,stroke-width:1.5px,color:#f8fafc;
    classDef model fill:#ede9fe,stroke:#7c3aed,stroke-width:2px,color:#2e1065;
    classDef code fill:#f8fafc,stroke:#64748b,stroke-width:1.5px,color:#0f172a;
    classDef env fill:#eff6ff,stroke:#3b82f6,stroke-width:1.5px,color:#0c4a6e;
    classDef obs fill:#f0fdf4,stroke:#16a34a,stroke-width:1.5px,color:#14532d;
    classDef deny fill:#fef2f2,stroke:#ef4444,stroke-width:1.5px,color:#7f1d1d;
    classDef ok fill:#ecfdf5,stroke:#10b981,stroke-width:1.5px,color:#064e3b;
    classDef human fill:#fffbeb,stroke:#f59e0b,stroke-width:1.5px,color:#78350f;
    class IN,OUT io;
    class CLS,DISP,FMT model;
    class WARM,NORM,SEC,OTHER,LED,REF code;
    class TOOLS,HELP env;
    class OBS obs;
    style S0 fill:#eff6ff,stroke:#bfdbfe,color:#0f172a;
    style S1 fill:#fff7ed,stroke:#fed7aa,color:#0f172a;
    style S2 fill:#f5f3ff,stroke:#ddd6fe,color:#0f172a;
    style S3 fill:#ecfeff,stroke:#a5f3fc,color:#0f172a;
